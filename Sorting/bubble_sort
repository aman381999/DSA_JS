let arr = [6, 0, -1, 3, 9, 12, 1];

function bubbleSort(arr) {
    let n = arr.length;

    for (let i = 0; i < (n - 1); i++) {

        //to less down the count of iteration if the iteration is still pending and the array is sorted before

        let isSwapped = false;
        for (let j = 0; j < (n - 1 - i); j++) {
            if (arr[j] > arr[j + 1]) {
                let temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
                isSwapped = true;
            }
        }

        //if the array did not swapped then break the loop because the array is sorted 
        if(!isSwapped) break
    }

    return arr;
}

