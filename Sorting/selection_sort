let arr = [6, 0, -1, 3, 9, 12, 1];

function bubbleSort(arr) {
    let n = arr.length;

    for (let i = 0; i < (n - 1); i++) {
        let min = i;

        for (let j = i + 1; j < n; j++){
            if (arr[min] > arr[j]) {
                let temp = arr[i];
                arr[min] = arr[j];
                arr[j] = temp;
            }
        }
    }

    return arr;
}

console.log(bubbleSort(arr))
